#Область ПрограммныйИнтерфейс

// Открывает транзакцию, ставит управляемую блокировку на ПервоеПространство,
// ждёт ПаузаСекунд, затем ставит блокировку на ВтороеПространство и фиксирует транзакцию.
//
// Сценарий тренировки взаимоблокировок:
//  Поток 1: (A -> B) - с паузой между захватом A и попыткой захвата B.
//  Поток 2: (B -> A) - параллельно, с паузой между B и A.
//  Если оба потока успели взять свой первый ресурс до истечения паузы,
//  на втором захвате возникает дедлок и одно из соединений получает исключение.
//
// Параметры:
//  ПервоеПространство  - Строка - пространство первой блокировки, например "Константа.ЗаголовокСистемы".
//  ВтороеПространство  - Строка - пространство второй блокировки, например "Константа.ПрефиксПоследнегоАвтономногоРабочегоМеста".
//  ПаузаСекунд         - Число  - длительность паузы между двумя захватами.
//
Процедура ВыполнитьПотокБлокировок(Знач ПервоеПространство, Знач ВтороеПространство, Знач ПаузаСекунд) Экспорт

	НачатьТранзакцию();
	Попытка

		БлокировкаПервая = Новый БлокировкаДанных;
		ЭлементПервый = БлокировкаПервая.Добавить(ПервоеПространство);
		ЭлементПервый.Режим = РежимБлокировкиДанных.Исключительный;
		БлокировкаПервая.Заблокировать();

		ПриостановитьПоток(ПаузаСекунд);

		БлокировкаВторая = Новый БлокировкаДанных;
		ЭлементВторой = БлокировкаВторая.Добавить(ВтороеПространство);
		ЭлементВторой.Режим = РежимБлокировкиДанных.Исключительный;
		БлокировкаВторая.Заблокировать();

		ЗафиксироватьТранзакцию();

	Исключение
		ОтменитьТранзакцию();
		ВызватьИсключение;
	КонецПопытки;

КонецПроцедуры

#КонецОбласти

#Область СлужебныеПроцедурыИФункции

// Активное ожидание: на сервере 1С нет штатного Sleep, а для учебной демонстрации
// короткая пауза в несколько секунд допустима.
//
// Параметры:
//  Секунд - Число - длительность паузы в секундах.
//
Процедура ПриостановитьПоток(Знач Секунд)

	МиллисекундВСекунде = 1000;
	КонечнаяМеткаМс = ТекущаяУниверсальнаяДатаВМиллисекундах() + Секунд * МиллисекундВСекунде;
	Пока ТекущаяУниверсальнаяДатаВМиллисекундах() < КонечнаяМеткаМс Цикл
		Продолжить;
	КонецЦикла;

КонецПроцедуры

#КонецОбласти
